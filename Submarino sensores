int lampara = 0, Emotores = 1, Emodooperacion = 2;
float profundidad = 1;
float velocidadX = 0;
bool movimientoDetectado;
unsigned long tiempoAnterior = 0;

int movimiento = 1;
const float UMBRAL_ANGULO = 10.0;
const float UMBRAL_ANGULOYAW = 20.0;
const float UMBRAL_GIRO = 20.0;
int velocidad = 1;
float presure = 0;
int disradsuper1 = 0, disradinferior = 0, disradsuper2 = 0, tem = 0;
int distotalradf = 0;

SoftwareSerial rs485(RX_RS485, TX_RS485);
int SL1trigPin = 2, SL1echoPin = 3;
int SL2trigPin = 6, SL2echoPin = 7;
int SItrigPin = 10, SIechoPin = 11;
int duracionSL1 = 0, distanciaSL1 = 0;
int duracionSL2 = 0, distanciaSL2 = 0;
int duracionSI = 0, distanciaSI = 0;
int anguloradar = 0, dis = 0;
