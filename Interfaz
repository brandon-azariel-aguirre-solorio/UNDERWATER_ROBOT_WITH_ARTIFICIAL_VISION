    def update_radar(self):

        self.radar_canvas.delete("all")

        # Dibuja el círculo del radar
        self.radar_canvas.create_oval(10, 10, 290, 290, outline='green', width=5)
        self.radar_canvas.create_line(150, 0, 150, 300, fill="green", width=1)
        self.radar_canvas.create_line(0, 150, 300, 150, fill="green", width=5)

          # Incrementa el radio del pulso
        self.pulse_radius += 5
        if self.pulse_radius > 140:
            self.pulse_radius = 0

        # Dibuja el pulso circular expandiéndose
        self.radar_canvas.create_oval(
            150 - self.pulse_radius, 150 - self.pulse_radius,
            150 + self.pulse_radius, 150 + self.pulse_radius,
            outline='green', width=5
        )

     # Verifica detecciones y dibuja ondas rojas
        for distancia, angulo in self.radar_points:
            if abs(distancia - self.pulse_radius) < 5:
                # Detección: dibuja onda roja (círculo completo)
                self.radar_canvas.create_oval(
                    150 - distancia, 150 - distancia, 150 + distancia, 150 + distancia,
                    outline='dark blue', width=2
                )
                # Muestra la distancia en la parte derecha
                if self.distance_text:
                    self.radar_canvas.delete(self.distance_text)
                self.distance_text = self.radar_canvas.create_text(
                    280, 20, text=f"Distancia: {distancia}", fill="white", anchor=tk.E
                )
        self.root.after(50, self.update_radar)

