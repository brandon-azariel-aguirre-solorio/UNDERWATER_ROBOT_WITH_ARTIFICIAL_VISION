    def actualizar_puertos(self):
        puertos_disponibles = [port.device for port in serial.tools.list_ports.comports()]
        self.combo_puertos['values'] = puertos_disponibles
        if puertos_disponibles:
            self.combo_puertos.current(0)
        self.root.after(2000, self.actualizar_puertos)

    def read_serial(self):
        try:
            if hasattr(self, 'Ser') and self.Ser and self.Ser.in_waiting > 0:
                respuesta = self.Ser.readline().decode('utf-8').rstrip()
                self.coneccionestado.config(text=f"Estado: {respuesta}")

                fragmentos = respuesta.split(",")

                if len(fragmentos) >= 5:
                    Eprofundidad, Econexion, Evel, Etem, Epreci = fragmentos[0], fragmentos[1], fragmentos[2], fragmentos[3],fragmentos[4]
                    self.coneccionestado.config(text=f"Estado de conexion: {Econexion}")
                    self.baterialevel.config(text=f"Velocidad: {Evel} m/s")
                    self.profundidad.config(text=f"Nivel de profundidad: {Eprofundidad} Metros")
                    self.temperature.config(text=f"Temperatura: {Etem} °C")
                    self.precion.config(text=f"Precion: {Epreci} bar")
                # Actualizar datos del radar si están disponibles
                if len(fragmentos) >= 7:
                    try:
                        distancia = float(fragmentos[5])
                        angulo = float(fragmentos[6])
                        self.radar_points.append((distancia, angulo))
                        if len(self.radar_points) > 20:
                            self.radar_points.pop(0)
                    except ValueError:
                        print("Datos de radar no validos")

        except Exception as e:
            self.coneccionestado.config(text=f"Error: {e}")

        self.root.after(10, self.read_serial)
     
    def start_camera(self):
        if self.running:
            return
        self.running = True
        self.capture = cv2.VideoCapture(1)
        self.update_camera()
    
    def update_camera(self):
        if self.running and self.capture.isOpened():
            ret, frame = self.capture.read()
            results = model(frame)
            if ret:
                for result in results:
                    boxes = result.boxes.cpu().numpy()  # Obtiene los bounding boxes en formato numpy
                    if boxes is not None and len(boxes) > 0:
                        for box in boxes:
                            x1, y1, x2, y2 = map(int, box.xyxy[0])
                            confidence = box.conf[0]
                            class_id = int(box.cls[0])
                            class_name = model.names[class_id]
                            label = f'{class_name}: {confidence:.2f}'
            
                            # Dibuja el bounding box
                            cv2.rectangle(frame, (x1, y1), (x2, y2), (0, 255, 0), 2)
            
                            # Dibuja la etiqueta de la clase y la confianza
                            cv2.putText(frame, label, (x1, y1 - 10), cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 255, 0), 2)
                           
                img_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
                img_pil = Image.fromarray(img_rgb)
                img_tk = ImageTk.PhotoImage(image=img_pil)
                self.camera_label.configure(image=img_tk)
                self.camera_label.image = img_tk              
            self.camera_label.after(10, self.update_camera)
        else:
            self.stop_camera()

    def stop_camera(self):
        if self.capture is not None:
            self.capture.release()
        self.running = False
        if hasattr(self, 'Ser') and self.Ser and self.Ser.is_open:
            self.Ser.close()
        self.root.destroy()

