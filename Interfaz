    def update_camera(self):
        if self.running and self.capture.isOpened():
            ret, frame = self.capture.read()
            if ret:
                # Redimensionar la imagen para que coincida con la entrada del modelo
                img_resized = cv2.resize(frame, (350, 350))
                img_array = image.img_to_array(img_resized)
                img_array = np.expand_dims(img_array, axis=0) / 255.0  # Normalizar y agregar dimensión del batch

                # Hacer la predicción
                predictions = model.predict(img_array)
                predicted_class = np.argmax(predictions, axis=1)

                # Verifica la confianza
                if np.max(predictions) < 0.8:
                    predicted_name = "Especie desconocida"
                else:
                    predicted_name = class_names[predicted_class[0]]

                # Mostrar la predicción en el label
                self.prediction_label.configure(text=f"Especie identificada: {predicted_name}  \n")

                # Convertir a imagen para Tkinter
                self.photo = tk.PhotoImage(data=cv2.imencode('.png', frame)[1].tobytes())
                self.camera_label.configure(image=self.photo)
                self.camera_label.image = self.photo

            self.camera_label.after(10, self.update_camera)
        else:
            self.stop_camera()

    def stop_camera(self):
        if self.capture is not None:
            self.capture.release()
        self.running = False
        if self.Ser.is_open:
            self.Ser.close()
        self.root.destroy()
