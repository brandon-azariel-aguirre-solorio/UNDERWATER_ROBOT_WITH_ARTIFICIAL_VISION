    def start_camera(self):
        if self.running:
            return
        self.running = True
        self.capture = cv2.VideoCapture(1)
        self.update_camera()
    
    def read_serial(self): 
        try:
            if self.Ser.in_waiting > 0:
                respuesta = self.Ser.readline().decode('utf-8').rstrip()
                self.coneccionestado.config(text=f"Estado: {respuesta}")  # Actualiza el label al recibir
            
                # Extraer fragmentos separados por comas
                fragmentos = respuesta.split(",")  # Dividir la cadena por comas
            
                # Asignar fragmentos a variables
                if len(fragmentos) >= 3:  # Asegúrate de que hay suficientes fragmentos
                    Eprofundidad, Econexion, Ebateria = fragmentos[0], fragmentos[1], fragmentos[2]
                    # Actualiza el estado con los fragmentos
                    self.coneccionestado.config(text=f"Estado de conexion: {Econexion}")
                    self.baterialevel.config(text=f"Nivel de energia: {Ebateria} %")
                    self.profundidad.config(text=f"Nivel de profundidad: {Eprofundidad} Metros")
                    #self.coneccionestado.config(text=f"Estado: {Econexion}")
                else:
                    self.coneccionestado.config(text="No hay suficientes fragmentos.")

        except Exception as e:
          self.coneccionestado.config(text=f"Error: {e}")  # Muestra el error en el label

        # Repite la lectura
        self.root.after(10, self.read_serial)
 
