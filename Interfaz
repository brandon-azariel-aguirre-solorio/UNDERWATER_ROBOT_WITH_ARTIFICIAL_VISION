    def update_radar(self):
        self.radar_canvas.delete("all") # Borra todo el contenido anterior del canvas

        canvas_width = 315
        canvas_height = 170

        # Posicionamiento del submarino (centrado horizontalmente, hacia la parte inferior)
        sub_center_x = (canvas_width / 2) - 20
        sub_image_height = self.car_image_tk.height() if self.car_image_tk else 0
        sub_image_width = self.car_image_tk.width() if self.car_image_tk else 0

        sub_center_y = canvas_height - (sub_image_height / 2) - 50

        # Dibujar la imagen del submarino
        if self.car_image_tk:
            self.radar_canvas.create_image(sub_center_x, sub_center_y, image=self.car_image_tk, anchor=tk.CENTER)

        # Definir las coordenadas de los bordes del submarino
        sub_left_edge = sub_center_x - sub_image_width / 2
        sub_right_edge = sub_center_x + sub_image_width / 2
        sub_top_edge = sub_center_y - sub_image_height / 2
        sub_bottom_edge = sub_center_y + sub_image_height / 2

        # Definir los orígenes del radar desde los bordes del submarino
        origin_bottom = (sub_center_x, sub_bottom_edge)
        origin_left = (sub_left_edge, sub_center_y)
        origin_right = (sub_right_edge, sub_center_y)
        origin_front = (sub_center_x, sub_top_edge)

        # Calcular el radio máximo para las ondas (sin cambios importantes aquí)
        max_radius_bottom = canvas_height - sub_bottom_edge - 0
        max_radius_left = sub_left_edge - 10
        max_radius_right = canvas_width - sub_right_edge - 10
        max_radius_front = sub_top_edge - 10

        max_display_radius = min(max_radius_bottom, max_radius_left, max_radius_right, max_radius_front)
        if max_display_radius < 45:
            max_display_radius = 45

        num_arcs = 8
        arc_step_pixels = max_display_radius / num_arcs

        # --- NUEVA LÓGICA: Determinar el color global de las ondas ---
        current_closest_dist = float('inf') # Inicializa con una distancia muy grande

        # Encuentra la distancia más cercana si hay puntos en self.radar_points
        if self.radar_points:
            for dist, _ in self.radar_points:
                if dist < current_closest_dist:
                    current_closest_dist = dist

        # Define los umbrales de distancia para los cambios de color
        # Utiliza la distancia más cercana del sensor para determinar el color de todas las ondas
        if current_closest_dist <= 15: # Muy cerca
            global_arc_color = 'red'
        elif current_closest_dist <= 25: # Cerca
            global_arc_color = 'yellow'
        else: # Distancia segura o no hay objetos
            global_arc_color = 'green' # Puedes usar 'dark green' si prefieres

        # --- Fin de la nueva lógica de color global ---

        # Dibujar arcos desde los bordes del submarino con el color global
        for i in range(1, num_arcs + 1):
            radius = i * arc_step_pixels

            # Arcos desde el borde inferior (extendiéndose hacia abajo)
            self.radar_canvas.create_arc(
                origin_bottom[0] - radius, origin_bottom[1] - radius,
                origin_bottom[0] + radius, origin_bottom[1] + radius,
                start=220, extent=100, outline=global_arc_color, width=1, style=tk.ARC
            )
            # Arcos desde el borde derecho (extendiéndose hacia la derecha)
            self.radar_canvas.create_arc(
                origin_right[0] - radius, origin_right[1] - radius + 30, # +30 para desplazarlo hacia abajo
                origin_right[0] + radius, origin_right[1] + radius + 30,
                start=320, extent=100, outline=global_arc_color, width=1, style=tk.ARC
            )
        # Actualizar el texto de distancia (usando la distancia más cercana)
        if current_closest_dist != float('inf'): # Si se detectó algo
            latest_dist_to_display = current_closest_dist
            if self.distance_text:
                self.radar_canvas.delete(self.distance_text)
            self.distance_text = self.radar_canvas.create_text(
                canvas_width / 2, 10,
                text=f"Distancia más cercana: {latest_dist_to_display:.2f} cm", fill="white", anchor=tk.N
            )
        else: # Si no hay puntos de radar
            if self.distance_text:
                self.radar_canvas.delete(self.distance_text)
            self.distance_text = self.radar_canvas.create_text(
                canvas_width / 2, 10,
                text="Esperando datos de radar...", fill="white", anchor=tk.N
            )

        self.root.after(50, self.update_radar) # Continuar actualizando el radar
  
    def update_motores(self):
        self.motor_canvas.delete("all") # Borra todo el contenido anterior del canvas

        canvas_width = 315
        canvas_height = 180

        # Posicionamiento del submarino (centrado horizontalmente, hacia la parte inferior)
        sub_center_x = (canvas_width / 2) - 0
        sub_image_height = self.subma_image_tk.height() if self.subma_image_tk else 0
        sub_image_width = self.subma_image_tk.width() if self.subma_image_tk else 0

        sub_center_y = canvas_height - (sub_image_height / 2) - 80

        # Dibujar la imagen del submarino
        if self.subma_image_tk:
            self.motor_canvas.create_image(sub_center_x, sub_center_y, image=self.subma_image_tk, anchor=tk.CENTER)

        # Definir las coordenadas de los bordes del submarino
        sub_left_edge = sub_center_x - sub_image_width / 2
        sub_right_edge = sub_center_x + sub_image_width / 2
        sub_top_edge = sub_center_y - sub_image_height / 2
        sub_bottom_edge = sub_center_y + sub_image_height / 2 

        # Definir los orígenes del radar desde los bordes del submarino
        origin_bottom = (sub_center_x+65, sub_bottom_edge)
        origin_bottom2 = (sub_center_x-65, sub_bottom_edge)
        origin_left = (sub_left_edge, sub_center_y)
        origin_right = (sub_right_edge, sub_center_y)
        origin_front = (sub_center_x, sub_top_edge)

        # Calcular el radio máximo para las ondas (sin cambios importantes aquí)
        max_radius_bottom = canvas_height - sub_bottom_edge - 0
        max_radius_left = sub_left_edge - 10
        max_radius_right = canvas_width - sub_right_edge - 10
        max_radius_front = sub_top_edge - 10

        max_display_radius = min(max_radius_bottom, max_radius_left, max_radius_right, max_radius_front)
        if max_display_radius < 45:
            max_display_radius = 45

        num_arcs = 8
        arc_step_pixels = max_display_radius / num_arcs

        global_arc_color = 'blue' # Puedes usar 'dark green' si prefieres
        # Dibujar arcos desde los bordes del submarino con el color global
        for i in range(1, num_arcs + 1):
            radius = i * arc_step_pixels

            # Arcos desde el borde inferior (extendiéndose hacia abajo)
            self.motor_canvas.create_arc(
                origin_bottom[0] - radius, origin_bottom[1] - radius+8,
                origin_bottom[0] + radius, origin_bottom[1] + radius+8,
                start=220, extent=100, outline=global_arc_color, width=1, style=tk.ARC
            )
            self.motor_canvas.create_arc(
                origin_bottom2[0] - radius, origin_bottom2[1] - radius+8,
                origin_bottom2[0] + radius, origin_bottom2[1] + radius+8,
                start=220, extent=100, outline=global_arc_color, width=1, style=tk.ARC
            )
            # Arco
            # Arcos desde el borde derecho (extendiéndose hacia la derecha)
           # self.motor_canvas.create_arc(
            #    origin_right[0] - radius, origin_right[1] - radius + 30, # +30 para desplazarlo hacia abajo
             #   origin_right[0] + radius, origin_right[1] + radius + 30,
              #  start=320, extent=100, outline=global_arc_color, width=1, style=tk.ARC
            #)

        self.root.after(50, self.update_motores) # Continuar actualizando el radar

if __name__ == "__main__":
